  "keyFeatures": [
    "CLI tool for recording scripted browser interactions as MP4, GIF, or WebM videos",
    "JSON-based configuration with IDE autocompletion via JSON Schema",
    "Automated Chrome and ffmpeg installation to user cache directory",
    "Cursor animation and keystroke HUD overlays with customizable themes",
    "Multiple action types: click, type, drag, scroll, key combos, navigation, and screenshots",
    "Watch mode for config changes and re-compositing without re-recording",
    "60fps screen capture with Chrome DevTools Protocol",
    "Shared step files for reusable automation sequences"
  ],
